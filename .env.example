# Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# X (Twitter) API — OAuth 1.0a user context (required for posting)
# Get these from https://developer.x.com/ → your app
X_OAUTH_CONSUMER_KEY=your_consumer_key_here
X_OAUTH_CONSUMER_SECRET=your_consumer_secret_here
X_OAUTH_ACCESS_TOKEN=your_access_token_here
X_OAUTH_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Your X handle (no @)
X_HANDLE=example_user

# Path to the voice/manifesto prompt the drafter uses
VOICE_PROMPT_PATH=prompts/manifesto.md
